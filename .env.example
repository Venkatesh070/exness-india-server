PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/exness_india?retryWrites=true&w=majority&appName=Cluster0

# JWT (generate secure random strings, min 32 chars)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
ENCRYPTION_KEY=change_me_encryption_key_32_chars

# Firebase — same values as alpha-trade-demo (VITE_FIREBASE_* + service account JSON)
FIREBASE_PROJECT_ID=exness-india
FIREBASE_WEB_API_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Resend — OTP emails (https://resend.com)
# API key from Resend → API Keys (starts with re_)
RESEND_API_KEY=
# Must be a verified sender/domain in Resend (or onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=noreply@exness-india.com
RESEND_FROM_NAME=Exness India

# Redis (disabled for now — cache uses in-memory store)
# REDIS_URL=redis://localhost:6379

# AWS S3 (optional — for KYC uploads)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
