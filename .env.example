PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/exness_india?retryWrites=true&w=majority&appName=Cluster0

# JWT (generate secure random strings, min 32 chars)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
ENCRYPTION_KEY=change_me_encryption_key_32_chars

# Firebase — same values as alpha-trade-demo (VITE_FIREBASE_* + service account JSON)
FIREBASE_PROJECT_ID=exness-india
FIREBASE_WEB_API_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Brevo — pick ONE method below
# Recommended: API key from Brevo → Settings → SMTP & API → API Keys (starts with xkeysib-)
BREVO_API_KEY=

# Alternative: SMTP from Brevo → Settings → SMTP & API → SMTP tab
# BREVO_SMTP_USER = "SMTP login" on that page (often xxxxx@smtp-brevo.com, NOT your Gmail)
# BREVO_SMTP_PASS = SMTP key (starts with xsmtpsib-)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# Must be a verified sender in Brevo → Senders & Domains
BREVO_FROM_EMAIL=thanneeruvenkey007@gmail.com
BREVO_FROM_NAME=Exness India

# Redis (disabled for now — cache uses in-memory store)
# REDIS_URL=redis://localhost:6379

# AWS S3 (optional — for KYC uploads)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
