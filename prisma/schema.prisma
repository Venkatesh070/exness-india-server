generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum KycStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
}

model User {
  id             String         @id @default(uuid())
  firebaseUid    String?        @unique @map("firebase_uid")
  email          String         @unique
  passwordHash   String         @map("password_hash")
  emailVerified  Boolean        @default(false) @map("email_verified")
  status         UserStatus     @default(PENDING)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  profile        Profile?
  kyc            Kyc?
  bankAccounts   BankAccount[]
  refreshTokens  RefreshToken[]
  emailOtps      EmailOtp[]

  @@map("users")
}

model EmailOtp {
  id              String   @id @default(uuid())
  email           String
  otpHash         String   @map("otp_hash")
  passwordEnc     String   @map("password_enc")
  expiresAt       DateTime @map("expires_at")
  attempts        Int      @default(0)
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  userId          String?  @map("user_id")
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("email_otps")
}

model Profile {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  dob        DateTime?
  gender     String?
  occupation String?
  income     String?
  address    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Kyc {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  status            KycStatus @default(NOT_STARTED)
  pan               String?
  panVerified       Boolean   @default(false) @map("pan_verified")
  aadhaarReference  String?   @map("aadhaar_reference")
  aadhaarVerified   Boolean   @default(false) @map("aadhaar_verified")
  selfieUrl         String?   @map("selfie_url")
  addressVerified   Boolean   @default(false) @map("address_verified")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc")
}

model BankAccount {
  id                      String   @id @default(uuid())
  userId                  String   @map("user_id")
  bankName                String   @map("bank_name")
  accountHolder           String   @map("account_holder")
  accountNumberEncrypted  String   @map("account_number_encrypted")
  ifsc                    String
  verified                Boolean  @default(false)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_accounts")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
